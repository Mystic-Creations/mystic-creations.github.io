---
import ProjectTemplate from './project.astro';
---

<center><h2><u>Our Projects</u></h2></center>

<div id="projects-grid-container"></div>

<center><p style="color: var(--text-muted); margin-top: 20px;"><small><i>Project details fetched from Modrinth</i></small></p></center>

<hr>

<ProjectTemplate />

<script src='./projects.ts'></script>

{/* global style so that it does not depend on Astro attributes being set */}
<style is:global>
  /* Projects grid - rows align so cards in the same row match height */
  .projects-grid {
  	display: grid;
  	grid-template-columns: repeat(3, 1fr);
  	gap: 14px;
  	margin-top: 8px;
  	align-items: stretch;
  }
</style>
