---
import Layout from '../layouts/Layout.astro';

import Projects from '../components/home/projects.astro';
import News from '../components/home/news.astro';
---

<Layout sidebarActive='home'>

  <header slot="before-card" class="site-header">
    <h1 class="site-title">WELCOME</h1>
    <h4 style="margin-top: -2px; margin-bottom: -5px;">TO</h4>
  </header>

  <div>
    <img src="/assets/render1.png" alt="Lumynity Studios Title Card" class="specifically-render1">
    <hr>

    <center><h2><u>About Us</u></h2></center>

    <p>
      Founded and led by <a href="https://x.com/JustMiliVT">JustMili</a>, Lumynity Studios is a "small" team of programmers, artists, 
      writers, builders, translators and play-testers.<br>
      We create whatever comes to our minds at the time and commit to it in the long run.<br>
      <small>(not so small afterall, though many of us do take multiple jobs at once)</small><br>
      <br>
      We love doing what we're doing, and thanks to our amazing community, contributors and collaborators we are where we stand today.
    </p>

    <hr style="margin-top: 25px;">
  </div>

  <div>
    <!-- Move PROJECTS here instead of an import -->
  </div>

  <div>
    <!-- Move NEWS here instead of an import -->
  </div>

  <Projects />
  <News />

</Layout>

<style>
  .site-header {
  	width: 100%;
  	max-width: 950px;
  	padding: 0 4px 12px;
  	text-align: center;
  }
  .site-title {
  	margin: 0;
  	font-size: 2rem;
  	font-weight: 700;
  	color: var(--text);
  	letter-spacing: 0.08em;
  }
</style>

