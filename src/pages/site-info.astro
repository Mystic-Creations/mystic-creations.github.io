---
import Layout from '../layouts/Layout.astro';
import '../page-css/site-info.css';
---

<!-- Hidden away page with all info about the site and other related information -->
<Layout sidebarActive='site-info'>
  <div class="site-info">

    <h2 class="info-section-title">Credits</h2>
    <section class="info-grid">
      <div class="info-card">
        <span class="info-role">Design</span>
        <a href="https://x.com/JustMiliVT" target="_blank" rel="noopener" class="info-name">JustMili</a>
      </div>
      <div class="info-card">
        <span class="info-role">Development</span>
        <span class="info-name">
          <a href="https://github.com/tomBoddaert" target="_blank" rel="noopener" class="info-name">tomBoddaert</a>, JustMili
        </span>
      </div>
      <div class="info-card">
        <span class="info-role">Logo & Branding</span>
        <a href="https://www.twitch.tv/flufaye" target="_blank" rel="noopener" class="info-name">Flufaye</a>
      </div>
    </section>

    <hr class="info-divider">

    <h2 class="info-section-title">Technical</h2>
    <section class="info-grid">
      <div class="info-card">
        <span class="info-role">Framework</span>
        <a href="https://astro.build" target="_blank" rel="noopener" class="info-name">Astro</a>
      </div>
      <div class="info-card">
        <span class="info-role">Runtime</span>
        <span class="info-name">
          <a href="https://deno.com" target="_blank" rel="noopener" class="info-name">Deno</a> + <a href="https://nodejs.org" target="_blank" rel="noopener" class="info-name">Node.js</a>
        </span>
      </div>
      <div class="info-card">
        <span class="info-role">Fetched APIs</span>
        <a href="https://docs.modrinth.com/api/" target="_blank" rel="noopener" class="info-name">Modrinth API v3</a>
      </div>

      <div class="info-grid-break"></div>

      <div class="info-card">
        <span class="info-role">Source</span>
        <a href="https://github.com/Lumynity-Studios/lumynitystudios.github.io" target="_blank" rel="noopener" class="info-name">github.com/Lumynity-Studios</a>
      </div>
      <div class="info-card">
        <span class="info-role">Hosting</span>
        <a href="https://pages.github.com" target="_blank" rel="noopener" class="info-name">GitHub Pages</a>
      </div>
      <div class="info-card">
        <span class="info-role">Domain</span>
        <a href="https://cloudflare.com" target="_blank" rel="noopener" class="info-name">Cloudflare</a>
      </div>

      <div class="info-grid-break"></div>

      <div class="info-card">
        <span class="info-role">License</span>
        <span class="info-name">All Rights Reserved</span>
      </div>
    </section>

    <hr class="info-divider">

    <h2 class="info-section-title">Fonts</h2>
    <section class="info-grid">
      <div class="info-card">
        <span class="info-role">UI</span>
        <span class="info-name font-preview-ui">Noto Sans</span>
        <span class="info-role" style="margin-top: 4px;">fallbacks</span>
        <span class="info-fallbacks">Arial, Inter</span>
      </div>
      <div class="info-card">
        <span class="info-role">Code</span>
        <span class="info-name font-preview-code">JetBrains Mono</span>
        <span class="info-role" style="margin-top: 4px;">fallbacks</span>
        <span class="info-fallbacks">Arial, Inter</span>
      </div>

      <div class="info-grid-break"></div>

      <div class="info-card">
        <span class="info-role">Brand Titlecards</span>
        <span class="info-name font-preview-code">Varela Round</span>
      </div>
    </section>

    <hr class="info-divider">

    <p class="info-footer-note">
      This page is not linked anywhere publicly - if you found it, good job.
    </p>

  </div>
</Layout>